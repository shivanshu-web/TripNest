<% layout("/layouts/boilerplate.ejs") %>


    <div class="row mt-3 ">

        <div>
            <div class="col-8 offset-2">
                <h3>
                    <%=listing.title%>
                </h3>
            </div>



            <div class="listing-card col-6 offset-2">
                <img src="<%=listing.image%>" class="card-img-top show-img" alt="...">
                <div class="card-body">
                    <p class="card-text">
                    <p> Owner = <i>
                            <%=listing.owner.username%>
                        </i></p>

                    <p>
                        <%=listing.description%>
                    </p>
                    <p> &#8377;<%=listing.price.toLocaleString("en-IN") %> </p>
                    <p>
                        <%=listing.location%>
                    </p>

                    </p>
                </div>
            </div>

        </div>


        <% if(currUser && currUser.equals(listing.owner._id)) {%>


            <div class="row">
                <div class="col-6 offset-2 btn-show">
                    <form method="get" action="http://localhost:8080/listings/<%= listing.id %>/update">
                        <button class="btn btn-dark add-btn">Edit</button>
                    </form>

                    <form method="post" action="http://localhost:8080/listings/<%= listing.id %>?_method=DELETE">
                        <button class="btn ms-2  btn-dark ">DELETE LIST</button>
                    </form>
                </div>



            </div>
            <% }%>


                <!-- this is a review part .. -->




                <div class="col-6 offset-2">
                    <hr>
                    <% if(currUser){%>


                        <h4>Leave a review</h4>
                        <form class="mb-3 mt-3 needs-validation" action="/listings/<%= listing.id %>/reviews"
                            method="POST" novalidate>
                            <div class="mb-3 mt-3">
                                <label for="rating" class="form-label">Rating </label>
                                <input type="range" min="1" max="5" name="review[rating]" class="form-range">

                            </div>
                           

                            <div class="mb-3 mt-3">
                                <label for="comment" class="form-label">Comments</label>
                                <textarea name="review[comment]" cols="25" rows="5" class="form-control"
                                    required></textarea>
                                <div class="invalid-feedback">
                                    Please enter a comment.
                                </div>

                            </div>
                            <button class="btn btn-outline-dark">Submit</button>
                        </form>
                        <% }%>
                            <p> <b>All Reviews</b></p>


                            <div class="row">

                                <% for(review of listing.reviews){%>
                                    <div class="card mt-1 col-5 ms-2  mb-2">
                                        <div class="card-body ms-2   ">
                                            <h5 class="card-title"> @<%= review.author.username %>
                                            </h5>
                                            <p class="card-text">
                                                <%= review.comment %>
                                            </p>
                                            <p class="card-text">
                                                <%= review.rating %> Star
                                            </p>
                                        </div>
                                        <form class="mb-3" method="POST"
                                            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                            <button class="btn btn-sm btn-dark">Delete</button>
                                        </form>

                                    </div>

                                    <%}%>
                            </div>

                </div>


    </div>